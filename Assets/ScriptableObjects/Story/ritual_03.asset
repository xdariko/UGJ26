  m_Script: {fileID: 11500000, guid: 9eae88fb23cd44843a4b2027ecc3248a, type: 3}
  m_Name: ritual_03
  m_EditorClassIdentifier: Assembly-CSharp::StorySequenceData
  id: ritual_03
  lines:
  - text: "\u0422\u0440\u0435\u0442\u0438\u0439 \u0440\u0438\u0442\u0443\u0430\u043B
      \u0437\u0430\u0432\u0435\u0440\u0448\u0451\u043D."
  - text: "\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u044F\u044F \u0432\u043E\u043B\u044F
      \u0438\u0441\u043F\u043E\u043B\u043D\u0435\u043D\u0430.  \n\u041D\u0430\u0441\u043B\u0435\u0434\u0438\u0435
      \u0432\u0435\u0434\u044C\u043C\u044B \u043F\u0435\u0440\u0435\u0434\u0430\u043D\u043E
      \u0431\u0435\u0437 \u043E\u0441\u0442\u0430\u0442\u043A\u0430."
  - text: "\u041D\u043E \u0432\u043C\u0435\u0441\u0442\u0435 \u0441 \u043D\u0438\u043C
      \u043F\u0440\u0438\u0448\u043B\u043E \u0438 \u043D\u0435\u0447\u0442\u043E
      \u0431\u043E\u043B\u044C\u0448\u0435\u0435, \u0447\u0435\u043C \u043F\u0440\u043E\u0441\u0442\u043E
      \u0441\u0438\u043B\u0430."
  - text: "\u041A\u043E\u0437\u0430 \u0438\u0441\u0447\u0435\u0437\u043B\u0430 \u0432
      \u043F\u043B\u0430\u043C\u0435\u043D\u0438 \u0440\u0438\u0442\u0443\u0430\u043B\u0430, 
      \n\u0430 \u0432\u044B\u0448\u043B\u0430 \u0438\u0437 \u043D\u0435\u0433\u043E
      \u0436\u0435\u043D\u0449\u0438\u043D\u0430  \n\u0441 \u0438\u043C\u0435\u043D\u0435\u043C
      \u0432\u0435\u0434\u044C\u043C\u044B, \u0435\u0451 \u043B\u0438\u0446\u043E\u043C
      \u0438 \u0435\u0451 \u043C\u0430\u0433\u0438\u0435\u0439."
  - text: "\u0427\u0435\u0440\u0442\u0438 \u0441\u043A\u043B\u043E\u043D\u0438\u043B\u0438
      \u0433\u043E\u043B\u043E\u0432\u044B."
  - text: "\u041D\u043E \u0434\u0430\u0436\u0435 \u043E\u043D\u0438 \u043D\u0435
      \u0437\u043D\u0430\u043B\u0438, \u043A\u043E\u043C\u0443 \u0441\u043B\u0443\u0436\u0430\u0442
      \u0442\u0435\u043F\u0435\u0440\u044C:  \n\u043D\u0430\u0441\u043B\u0435\u0434\u043D\u0438\u0446\u0435,
      \u0447\u0442\u043E \u043F\u0440\u0438\u043D\u044F\u043B\u0430 \u0447\u0443\u0436\u043E\u0435
      \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435,  \n\u0438\u043B\u0438 \u0432\u0435\u0434\u044C\u043C\u0435, 
      \u0447\u0442\u043E \u0432\u0441\u0451 \u043F\u0440\u043E\u0434\u0443\u043C\u0430\u043B\u0430
      \u0435\u0449\u0451 \u0434\u043E \u0441\u0432\u043E\u0435\u0433\u043E \u0438\u0441\u0447\u0435\u0437\u043D\u043E\u0432\u0435\u043D\u0438\u044F."
