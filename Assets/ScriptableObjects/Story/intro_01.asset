  m_Script: {fileID: 11500000, guid: 9eae88fb23cd44843a4b2027ecc3248a, type: 3}
  m_Name: intro_01
  m_EditorClassIdentifier: Assembly-CSharp::StorySequenceData
  id: intro_01
  lines:
  - text: "\u0416\u0438\u043B\u0430 \u0443 \u0432\u0435\u0434\u044C\u043C\u044B \u043A\u043E\u0437\u0430."
  - text: "\u041D\u0435 \u043E\u0431\u044B\u0447\u043D\u0430\u044F \u043A\u043E\u0437\u0430 
      \u2014 \u0444\u0430\u043C\u0438\u043B\u044C\u044F\u0440.  \n\u0415\u043B\u0430
      \u0441 \u0440\u0443\u043A\u0438, \u0441\u043F\u0430\u043B\u0430 \u0443 \u043F\u0435\u0447\u0438,
      \u0445\u043E\u0434\u0438\u043B\u0430 \u0437\u0430 \u0445\u043E\u0437\u044F\u0439\u043A\u043E\u0439
      \u0442\u0435\u043D\u044C\u044E."
  - text: "\u0410 \u043F\u043E\u0442\u043E\u043C \u0432\u0435\u0434\u044C\u043C\u0430
      \u0438\u0441\u0447\u0435\u0437\u043B\u0430. "
  - text: "\u0411\u0435\u0437 \u043A\u0440\u0438\u043A\u0430, \u0431\u0435\u0437
      \u043A\u0440\u043E\u0432\u0438, \u0431\u0435\u0437 \u0441\u043B\u0435\u0434\u0430. 
      \n\u0421\u043B\u043E\u0432\u043D\u043E \u043D\u043E\u0447\u044C \u0432\u0437\u044F\u043B\u0430
      \u0441\u0432\u043E\u0451 \u0438 \u043D\u0438\u043A\u043E\u043C\u0443 \u043D\u0438\u0447\u0435\u0433\u043E
      \u043D\u0435 \u0441\u043A\u0430\u0437\u0430\u043B\u0430."
  - text: "\u0422\u043E\u043B\u044C\u043A\u043E \u043A \u0443\u0442\u0440\u0443 \u0432
      \u044F\u0432\u0438\u043B\u0438\u0441\u044C \u0447\u0435\u0440\u0442\u0438. 
      \n\u0421\u0442\u0430\u0440\u044B\u0435, \u0447\u0443\u0436\u0438\u0435, \u0441\u0432\u044F\u0437\u0430\u043D\u043D\u044B\u0435
      \u0432\u0435\u0434\u044C\u043C\u043E\u0432\u0441\u043A\u0438\u043C \u0434\u043E\u0433\u043E\u0432\u043E\u0440\u043E\u043C."
  - text: "\u041E\u043D\u0438 \u043D\u0435 \u0438\u0441\u043A\u0430\u043B\u0438 \u0445\u043E\u0437\u044F\u0439\u043A\u0443. 
      \n\u041E\u043D\u0438 \u043F\u0440\u0438\u0448\u043B\u0438 \u0438\u0441\u043F\u043E\u043B\u043D\u0438\u0442\u044C
      \u0435\u0451 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044E\u044E \u0432\u043E\u043B\u044E."
  - text: "\u0412\u0441\u0451, \u0447\u0442\u043E \u0432\u0435\u0434\u044C\u043C\u0430
      \u043E\u0441\u0442\u0430\u0432\u0438\u043B\u0430 \u043F\u043E\u0441\u043B\u0435
      \u0441\u0435\u0431\u044F,  \n\u0432\u0441\u0451 \u0435\u0451 \u0437\u043D\u0430\u043D\u0438\u0435,
      \u0441\u0438\u043B\u0430 \u0438 \u043F\u0440\u0430\u0432\u043E,  \n\u0437\u0430\u0432\u0435\u0449\u0430\u043D\u043E
      \u043A\u043E\u0437\u0435."
  - text: "\u041D\u043E \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E
      \u044D\u0442\u043E \u043D\u0435 \u0431\u0435\u0440\u0443\u0442 \u0432 \u0440\u0443\u043A\u0438,
      \u043A\u0430\u043A \u043C\u0435\u0448\u043E\u043A \u0441 \u043C\u043E\u043D\u0435\u0442\u043E\u0439. 
      \n\u0415\u0433\u043E \u043D\u0430\u0434\u043E \u0437\u0430\u0441\u043B\u0443\u0436\u0438\u0442\u044C."
  - text: "\u0422\u0440\u0438 \u0440\u0438\u0442\u0443\u0430\u043B\u0430.   \u0422\u0440\u0438
      \u0448\u0430\u0433\u0430 \u0442\u0443\u0434\u0430, \u043E\u0442\u043A\u0443\u0434\u0430
      \u043D\u0435 \u0432\u0441\u044F\u043A\u0438\u0439 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044F
      \u043F\u0440\u0435\u0436\u043D\u0438\u043C."
  - text: "\u0421\u043E\u0431\u0435\u0440\u0438 \u044D\u0444\u0438\u0440 \u0441 \u0434\u0435\u043C\u043E\u043D\u0438\u0447\u0435\u0441\u043A\u0438\u0445
      \u0442\u0432\u0430\u0440\u0435\u0439.   \u0418\u0441\u043F\u043E\u043B\u043D\u0438
      \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u044E\u044E \u0432\u043E\u043B\u044E
      \u0432\u0435\u0434\u044C\u043C\u044B. \u0418 \u0442\u043E\u0433\u0434\u0430
      \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E \u0441\u0442\u0430\u043D\u0435\u0442
      \u0442\u0432\u043E\u0438\u043C."
